                    <mxGeometry x="-100" y="838" width="60" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="qzggYJs0d6ae3CGitzp_-5" value="&lt;div style=&quot;line-height: 18px; color: rgb(191, 189, 182);&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;line-height: 18px; color: rgb(191, 189, 182);&quot;&gt;&lt;div style=&quot;white-space: pre; font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: light-dark(rgb(191, 189, 182), rgb(77, 75, 69));&quot;&gt;&lt;div style=&quot;color: rgb(191, 189, 182); background-color: rgb(13, 16, 23); line-height: 18px;&quot;&gt;&lt;div style=&quot;color: rgb(191, 189, 182); line-height: 18px;&quot;&gt;&lt;div style=&quot;color: rgb(191, 189, 182); line-height: 18px;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #ff8f40;&quot;&gt;import&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; { expect&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;,&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; test } &lt;/span&gt;&lt;span style=&quot;color: #ff8f40;&quot;&gt;from&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aad94c;&quot;&gt;&#39;vitest&#39;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #ff8f40;&quot;&gt;import&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; { sum } &lt;/span&gt;&lt;span style=&quot;color: #ff8f40;&quot;&gt;from&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aad94c;&quot;&gt;&#39;./sum.js&#39;&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #ffb454;&quot;&gt;test&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #aad94c;&quot;&gt;&#39;adds 1 + 2 to equal 3&#39;&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;,&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; () &lt;/span&gt;&lt;span style=&quot;color: #ff8f40;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;  &lt;/span&gt;&lt;span style=&quot;color: #ffb454;&quot;&gt;expect&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #ffb454;&quot;&gt;sum&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #d2a6ff;&quot;&gt;1&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;,&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d2a6ff;&quot;&gt;2&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;))&lt;/span&gt;&lt;span style=&quot;color: #f29668;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #ffb454;&quot;&gt;toBe&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #d2a6ff;&quot;&gt;3&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;})&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;align=left;rounded=1;arcSize=10;labelBackgroundColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="240" y="868" width="270" height="110" as="geometry"/>
