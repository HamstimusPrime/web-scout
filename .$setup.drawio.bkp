    <diagram id="W2Z77LvbsKS17rigjGGQ" name="setup">
        <mxGraphModel dx="779" dy="492" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="&lt;font style=&quot;font-size: 15px;&quot; face=&quot;Virgil Gs&quot;&gt;install &lt;/font&gt;&lt;font face=&quot;Courier New&quot; style=&quot;font-size: 15px;&quot;&gt;nvm&lt;/font&gt;&lt;font style=&quot;font-size: 15px;&quot; face=&quot;Virgil Gs&quot;&gt;&amp;nbsp;in order to be able to choose different versions of node to run your program depending on the needs of the project&lt;/font&gt;" style="whiteSpace=wrap;html=1;rounded=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=20;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="180" width="360" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="4" value="&lt;font face=&quot;Verdana&quot;&gt;1&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="-180" y="190" width="50" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="5" value="&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;Create a &lt;/font&gt;&lt;font style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot; face=&quot;Courier New&quot;&gt;.nvmrc&lt;/font&gt;&lt;font face=&quot;Virgil Gs&quot;&gt; file&lt;/font&gt;&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;In the file, you put the version of node you want in plain text. this tells nvm what version of node you want nvm to use. After this, run the command &lt;/font&gt;&lt;font style=&quot;background-color: rgb(255, 255, 153);&quot; face=&quot;Courier New&quot;&gt;nvm install&lt;/font&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;. it would look for the .nvmrc file and use the text in it to download, install and set the command line to use the version of node specified in the file.&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=15;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="310" width="430" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="6" value="&lt;font face=&quot;Verdana&quot;&gt;2&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="-180" y="320" width="50" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="7" value="&lt;font face=&quot;Virgil Gs&quot;&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;Initialize an npm project using the command&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;background-color: rgb(255, 255, 153);&quot; face=&quot;Courier New&quot;&gt;npm init&lt;/font&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=15;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="540" width="430" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="8" value="&lt;font face=&quot;Verdana&quot;&gt;3&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="-180" y="550" width="50" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="11" style="edgeStyle=none;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;sketch=1;curveFitting=1;jiggle=2;exitX=1;exitY=0.869;exitDx=0;exitDy=0;exitPerimeter=0;" parent="1" source="9" target="13" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="440" y="742.3076923076922" as="targetPoint"/>
                        <Array as="points"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="9" value="&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;We want to install a bunch of programs that would be useful when developing our application. These programs would be downloaded using the &lt;/font&gt;&lt;font style=&quot;background-color: rgb(255, 255, 153);&quot; face=&quot;Courier New&quot;&gt;-D&lt;/font&gt;&lt;font face=&quot;Virgil Gs&quot;&gt; flag to tells npm that the programs would be used for development and not for running the application. Using this flag registers the downloaded programs in&lt;/font&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot; face=&quot;Virgil Gs&quot;&gt;&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot; face=&quot;Virgil Gs&quot;&gt;&lt;span style=&quot;caret-color: rgb(255, 255, 255); font-size: medium; text-align: start;&quot;&gt;They go into&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;code style=&quot;caret-color: rgb(255, 255, 255); text-align: start; text-decoration-thickness: auto; text-decoration-style: solid; background-color: rgb(218, 214, 255);&quot; data-end=&quot;968&quot; data-start=&quot;951&quot;&gt;devDependencies&lt;/code&gt;&lt;span style=&quot;caret-color: rgb(255, 255, 255); font-size: medium; text-align: start;&quot;&gt;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;in&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;code style=&quot;caret-color: rgb(255, 255, 255); text-align: start; text-decoration-thickness: auto; text-decoration-style: solid; background-color: rgb(218, 214, 255);&quot; data-end=&quot;986&quot; data-start=&quot;972&quot;&gt;package.json&lt;/code&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;div&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;To in stall the programs, we run the command:&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px; background-color: rgb(153, 204, 255);&quot;&gt;&lt;font style=&quot;&quot; face=&quot;Courier New&quot;&gt;npm install -D typescript @types/node tsx&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=15;align=center;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="667" width="420" height="191" as="geometry"/>
                </mxCell>
                <mxCell id="10" value="&lt;font face=&quot;Verdana&quot;&gt;4&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="-180" y="697" width="50" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="13" value="&lt;font face=&quot;Virgil Gs&quot;&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;We download the following programs:&lt;/span&gt;&lt;/font&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Virgil Gs&amp;quot;; white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;font style=&quot;background-color: rgb(255, 255, 153);&quot; face=&quot;Courier New&quot;&gt;Typescript:&lt;/font&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;&amp;nbsp;The typescript compiler that compiles Typescript to JS&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Virgil Gs&amp;quot;; white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;font style=&quot;background-color: rgb(255, 255, 153);&quot; face=&quot;Courier New&quot;&gt;Types/node:&lt;/font&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;&lt;font&gt;&amp;nbsp;&lt;/font&gt;&lt;font&gt;This makes typescript see node methods and variables as types&lt;/font&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;font style=&quot;background-color: rgb(255, 255, 153);&quot; face=&quot;Courier New&quot;&gt;TSX:&lt;/font&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;&amp;nbsp;This is a convenience program that lets us run typescript appilcations without having to compile them&lt;/font&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#dae8fc;strokeColor=#9999FF;arcSize=15;align=left;" parent="1" vertex="1">
                    <mxGeometry x="480" y="770" width="700" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="16" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63); font-family: &amp;quot;Virgil Gs&amp;quot;; background-color: transparent;&quot;&gt;We configure the typescript compiler to behave in ways that we want.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;We want it to use esnext cos esnext has the latest compiling featueres for typescript&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;We want it to use the esnext import command to import modules&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;We want strict mode to check for as many errors as possible&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;we want the typescript compiler to search for files like Node does &quot;&lt;/font&gt;&lt;font style=&quot;background-color: rgb(255, 255, 153);&quot; face=&quot;Courier New&quot;&gt;moduleResolution: &quot;Node&quot;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;We set the compiler to only compile files inside of the folder with the name &quot;src&quot;:&lt;/font&gt;&lt;font face=&quot;Courier New&quot;&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;color: rgb(255, 255, 255); caret-color: rgb(255, 255, 255);&quot;&gt;&lt;span style=&quot;background-color: rgb(255, 255, 153);&quot;&gt;&quot;include&quot;: [&quot;./src/**/*.ts]&quot;&lt;/span&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;&lt;span style=&quot;caret-color: rgb(255, 255, 255);&quot;&gt;We set up the compiler to ignore all of the files inside of the folder called &quot;node_modules&quot;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=15;align=center;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="920" width="710" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="15" value="&lt;div style=&quot;font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; line-height: 18px; white-space: pre; color: rgb(191, 189, 182);&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;line-height: 18px; color: rgb(191, 189, 182);&quot;&gt;&lt;div style=&quot;color: light-dark(rgb(191, 189, 182), rgb(77, 75, 69));&quot;&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;{&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;  &lt;/span&gt;&lt;span style=&quot;color: rgb(57, 186, 230);&quot;&gt;&quot;compilerOptions&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt; &lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(191, 189, 182), rgb(77, 75, 69));&quot;&gt;&lt;span style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color: rgb(57, 186, 230);&quot;&gt;&quot;target&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 217, 76);&quot;&gt;&quot;esnext&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;//when compiling to JS, use the latest features&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(191, 189, 182), rgb(77, 75, 69));&quot;&gt;&lt;span style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color: rgb(57, 186, 230);&quot;&gt;&quot;module&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 217, 76);&quot;&gt;&quot;esnext&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;,&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(191, 189, 182), rgb(77, 75, 69));&quot;&gt;&lt;span style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color: rgb(57, 186, 230);&quot;&gt;&quot;strict&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(210, 166, 255);&quot;&gt;true&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;,&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(191, 189, 182), rgb(77, 75, 69));&quot;&gt;&lt;span style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color: rgb(57, 186, 230);&quot;&gt;&quot;moduleResolution&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 217, 76);&quot;&gt;&quot;Node&quot;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(191, 189, 182), rgb(77, 75, 69));&quot;&gt;&lt;span style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;  }&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;,&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(191, 189, 182), rgb(77, 75, 69));&quot;&gt;&lt;span style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;  &lt;/span&gt;&lt;span style=&quot;color: rgb(57, 186, 230);&quot;&gt;&quot;include&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt; [&lt;/span&gt;&lt;span style=&quot;color: rgb(170, 217, 76);&quot;&gt;&quot;./src/**/*.ts&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;]&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;,&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(191, 189, 182), rgb(77, 75, 69));&quot;&gt;&lt;span style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;  &lt;/span&gt;&lt;span style=&quot;color: rgb(57, 186, 230);&quot;&gt;&quot;exclude&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt; [&lt;/span&gt;&lt;span style=&quot;color: rgb(170, 217, 76);&quot;&gt;&quot;node_modules&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;]&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(191, 189, 182), rgb(77, 75, 69));&quot;&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;font color=&quot;rgba(0, 0, 0, 0)&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;align=left;rounded=1;arcSize=10;labelBackgroundColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="1090" width="520" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="17" value="&lt;font face=&quot;Verdana&quot;&gt;5&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="-180" y="950" width="50" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="19" value="&lt;div style=&quot;&quot;&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;we configure Node JS to use the &quot;module&quot; system of importing and exporting files, which basically treats all files with .js extensions as separate modules.&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;- We also setup a default command to run when we use the &lt;/font&gt;&lt;font style=&quot;background-color: rgb(255, 255, 153);&quot; face=&quot;Courier New&quot;&gt;npm run start&lt;/font&gt;&lt;font face=&quot;Virgil Gs&quot;&gt; command. in this case we run the command:&amp;nbsp;&lt;/font&gt;&lt;font style=&quot;background-color: rgb(255, 255, 153);&quot; face=&quot;Courier New&quot;&gt;tsx ./src/index.ts&lt;/font&gt;&lt;font face=&quot;Virgil Gs&quot;&gt; to run the index.ts application&amp;nbsp;&lt;/font&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=15;align=left;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="1360" width="710" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="20" value="&lt;font face=&quot;Verdana&quot;&gt;6&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="-180" y="1390" width="50" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="21" value="&lt;div style=&quot;line-height: 18px; white-space: pre; font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: rgb(191, 189, 182);&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;line-height: 18px; color: rgb(191, 189, 182);&quot;&gt;&lt;div style=&quot;color: light-dark(rgb(191, 189, 182), rgb(77, 75, 69));&quot;&gt;&lt;div style=&quot;color: rgb(191, 189, 182); background-color: rgb(13, 16, 23); line-height: 18px;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;...&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;  &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 217, 76);&quot;&gt;&quot;type&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 217, 76);&quot;&gt;&quot;module&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;, \\tells Node to use the module system of importing and exporting files&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;  &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 217, 76);&quot;&gt;&quot;scripts&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;: {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color: rgb(57, 186, 230);&quot;&gt;&quot;start&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 217, 76);&quot;&gt;&quot;tsx ./src/index.ts&quot; \\command that runs when `npm run` command is used&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;  },&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(191, 189, 182);&quot;&gt;...&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;align=left;rounded=1;arcSize=10;labelBackgroundColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="1470" width="650" height="110" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="BTUjhZTEkHV3vgLIV7G4" name="TDD setup">
        <mxGraphModel dx="1084" dy="492" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="cy92G19h1R4KJe0Kz787-1" value="&lt;span style=&quot;font-family: &amp;quot;Virgil Gs&amp;quot;; font-size: 15px;&quot;&gt;We use vitest to run our Tests. Vitest is a program that we need to download as a Development dependency (A bunch of programs used for our development processes). We download this using the command:&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 15px; background-color: rgb(255, 255, 153);&quot;&gt;&lt;font style=&quot;&quot; face=&quot;Courier New&quot;&gt;npm install -D vitest&lt;/font&gt;&lt;/span&gt;&lt;div&gt;&lt;br/&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=20;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="180" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="cy92G19h1R4KJe0Kz787-2" value="&lt;font face=&quot;Verdana&quot;&gt;2&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="-180" y="190" width="50" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="BOlTezBX7dCKfGD6kkjY-1" value="&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;We need to configure npm so that when we run the command &lt;/font&gt;&lt;font style=&quot;background-color: rgb(255, 255, 153);&quot; face=&quot;Courier New&quot;&gt;npm run test&lt;/font&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;, it runs a specific command. in our case, this command would be &lt;/font&gt;&lt;span style=&quot;background-color: rgb(255, 219, 235);&quot;&gt;&lt;font face=&quot;Courier New&quot;&gt;vitetest run&lt;/font&gt;&lt;/span&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;. vitetest command looks for files that end with the extension &lt;/font&gt;&lt;span style=&quot;font-family: &amp;quot;Virgil Gs&amp;quot;; background-color: rgb(218, 214, 255);&quot;&gt;.test.ts&lt;/span&gt;&lt;font face=&quot;Virgil Gs&quot;&gt; and executes them. this configuration happens by setting the value of the test field in package .json to &lt;/font&gt;&lt;span style=&quot;background-color: rgb(255, 219, 235);&quot;&gt;&lt;font face=&quot;Courier New&quot;&gt;vitetest run&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=20;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="360" width="420" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="BOlTezBX7dCKfGD6kkjY-2" value="&lt;font face=&quot;Verdana&quot;&gt;3&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="-180" y="370" width="50" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="ANJ4nTKsGwYzfAVbdUDC-1" value="&lt;div style=&quot;line-height: 18px; color: rgb(191, 189, 182);&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;line-height: 18px; color: rgb(191, 189, 182);&quot;&gt;&lt;div style=&quot;white-space: pre; font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: light-dark(rgb(191, 189, 182), rgb(77, 75, 69));&quot;&gt;&lt;div style=&quot;color: rgb(191, 189, 182); background-color: rgb(13, 16, 23); line-height: 18px;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;...&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #aad94c;&quot;&gt;&quot;scripts&quot;&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;: {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;  &lt;/span&gt;&lt;span style=&quot;color: #39bae6;&quot;&gt;&quot;start&quot;&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aad94c;&quot;&gt;&quot;tsx ./src/index.ts&quot;&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;  &lt;/span&gt;&lt;span style=&quot;color: #39bae6;&quot;&gt;&quot;test&quot;&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aad94c;&quot;&gt;&quot;vitest run&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;},&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;...&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;align=left;rounded=1;arcSize=10;labelBackgroundColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="520" width="230" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="Qsd0f4vL9r8jbvHKdChH-1" value="&lt;div&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;The Approach for our TDD would follow this pattern:&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;- Define the&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;- Write the Test logic inside the function&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Virgil Gs&quot;&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;- Write the code that passes the Test&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=20;align=left;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="10" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="Qsd0f4vL9r8jbvHKdChH-2" value="&lt;font face=&quot;Verdana&quot;&gt;1&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="-180" y="18" width="50" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="qzggYJs0d6ae3CGitzp_-1" value="&lt;font face=&quot;Virgil Gs&quot;&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;TDD works by importing functions or object setups from Modules and then tests if their output matches an expected value&lt;/span&gt;&lt;/font&gt;" style="whiteSpace=wrap;html=1;rounded=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=20;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="670" width="420" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="qzggYJs0d6ae3CGitzp_-2" value="&lt;font face=&quot;Verdana&quot;&gt;4&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="-180" y="680" width="50" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="qzggYJs0d6ae3CGitzp_-3" value="&lt;div style=&quot;line-height: 18px; color: rgb(191, 189, 182);&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;line-height: 18px; color: rgb(191, 189, 182);&quot;&gt;&lt;div style=&quot;white-space: pre; font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; color: light-dark(rgb(191, 189, 182), rgb(77, 75, 69));&quot;&gt;&lt;div style=&quot;color: rgb(191, 189, 182); background-color: rgb(13, 16, 23); line-height: 18px;&quot;&gt;&lt;div style=&quot;color: rgb(191, 189, 182); line-height: 18px;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #ff8f40;&quot;&gt;export&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ff8f40;&quot;&gt;function&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ffb454;&quot;&gt;sum&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #d2a6ff;&quot;&gt;a&lt;/span&gt;&lt;span style=&quot;color: #f29668;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #39bae6;&quot;&gt;number&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;,&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d2a6ff;&quot;&gt;b&lt;/span&gt;&lt;span style=&quot;color: #f29668;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #39bae6;&quot;&gt;number&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;) {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;  &lt;/span&gt;&lt;span style=&quot;color: #ff8f40;&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d2a6ff;&quot;&gt;a&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #f29668;&quot;&gt;+&lt;/span&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d2a6ff;&quot;&gt;b&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #bfbdb6;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;align=left;rounded=1;arcSize=10;labelBackgroundColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="-100" y="868" width="300" height="60" as="geometry"/>
                </mxCell>
